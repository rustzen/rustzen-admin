# Local development env file
# Copy to .env for local startup.
# Production should use config/app.env or systemd EnvironmentFile.
# Local development defaults to a hidden runtime root inside the repo.
# Production should set the runtime root explicitly for the deploy layout.
# Production must provide RUSTZEN_SQLITE_PATH.
# If RUSTZEN_ENV=production or prod, RUSTZEN_JWT_SECRET must be set explicitly
# and cannot use the development default.

# Storage
RUSTZEN_SQLITE_PATH=./data/db/admin.db
RUSTZEN_MONITOR_SQLITE_PATH=./data/db/monitor.db
RUSTZEN_INSIGHTS_SQLITE_PATH=./data/db/insights.db
RUSTZEN_REPORTS_SQLITE_PATH=./data/db/reports.db

# App
# Frontend dev server runs on 9800 in apps/web/vite.config.ts.
# Backend API (Axum) runs on this port.
RUSTZEN_APP_HOST=0.0.0.0
RUSTZEN_APP_PORT=9801
RUSTZEN_WORKER_HOST=127.0.0.1
RUSTZEN_MONITOR_PORT=9802
RUSTZEN_INSIGHTS_PORT=9803
RUSTZEN_REPORTS_PORT=9804

# Short-lived HMAC IPC contexts are derived from this secret.
# Production and release layouts must replace this value.
RUSTZEN_IPC_TOKEN=rustzen-dev-ipc-token-change-in-production

# Database connection pool
RUSTZEN_DB_MAX_CONN=4
RUSTZEN_DB_MIN_CONN=1
RUSTZEN_DB_CONN_TIMEOUT=10
# Idle connections older than 600 seconds are recycled. Set 0 to disable idle reaping.
RUSTZEN_DB_IDLE_TIMEOUT=600

# JWT (default: 7200 seconds = 2 hours)
# Development can omit this field and use the built-in default.
# Release packages carry this placeholder; production must replace it.
RUSTZEN_JWT_SECRET=rustzen-admin-release-{version}
RUSTZEN_JWT_EXPIRATION=7200

# Runtime root
# Local development uses .rustzen-admin under the repository root.
# Production deployment packages should set this to `.`.
RUSTZEN_RUNTIME_ROOT=.rustzen-admin

# Runtime paths derived from the runtime root
RUSTZEN_FILES_PREFIX=/resources
RUSTZEN_LOG_FILE_PREFIX=server
RUSTZEN_TIMEZONE=UTC
RUSTZEN_TASK_RUN_TIMEOUT_SECONDS=1800

# Deploy artifact signature verification.
# Local development can keep this disabled. `just build` enables it in the
# generated production config and writes the matching verify key automatically.
RUSTZEN_DEPLOY_SIGNATURE_REQUIRED=false
RUSTZEN_DEPLOY_VERIFY_KEY=
RUSTZEN_MONITOR_AGENT_RELEASE_URL=
RUSTZEN_MONITOR_AGENT_RELEASE_SHA256=
RUSTZEN_MONITOR_AGENT_RELEASE_VERSION=
RUSTZEN_MONITOR_AGENT_RELEASE_OS=
RUSTZEN_MONITOR_AGENT_RELEASE_ARCH=
RUSTZEN_MONITOR_AGENT_RELEASE_SIZE_BYTES=
RUSTZEN_MONITOR_AGENT_ROLLOUT_STAGE=
RUSTZEN_MONITOR_AGENT_CANARY_IDS=
RUSTZEN_MONITOR_AGENT_BATCH_PERCENT=0

# Logging
RUST_LOG=info
