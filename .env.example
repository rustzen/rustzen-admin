# Local development env file
# Copy to .env for local startup.
# Production should use config/app.env or systemd EnvironmentFile.
# Local development defaults to a hidden runtime root inside the repo.
# Production should set the runtime root explicitly for the deploy layout.
# Production must provide DATABASE_URL and RUSTZEN_JWT_SECRET.
# RUSTZEN_JWT_SECRET has no code default and must be set explicitly.

# Database
DATABASE_URL=postgres://your_username:your_password@localhost:5432/rustzen_admin

# App
RUSTZEN_APP_HOST=0.0.0.0
RUSTZEN_APP_PORT=8007

# Database connection pool
RUSTZEN_DB_MAX_CONN=4
RUSTZEN_DB_MIN_CONN=1
RUSTZEN_DB_CONN_TIMEOUT=10
# Idle connections older than 600 seconds are recycled. Set 0 to disable idle reaping.
RUSTZEN_DB_IDLE_TIMEOUT=600

# JWT
RUSTZEN_JWT_SECRET=replace-me
RUSTZEN_JWT_EXPIRATION=3600

# Runtime root
RUSTZEN_RUNTIME_ROOT=.rustzen-admin

# Runtime paths derived from the runtime root
RUSTZEN_FILES_PREFIX=/resources
RUSTZEN_LOG_FILE_PREFIX=server
RUSTZEN_LOG_RETENTION_DAYS=7

# Logging
RUST_LOG=info
