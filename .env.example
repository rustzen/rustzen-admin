# Production-only overrides.
# Local development needs no .env file; safe runtime defaults are built in.
# Replace both secret placeholders before starting production services.

RUSTZEN_ENV=production
RUSTZEN_RUNTIME_ROOT=.
RUSTZEN_JWT_SECRET=replace-me
RUSTZEN_IPC_TOKEN=replace-me
RUSTZEN_DEPLOY_SIGNATURE_REQUIRED=true
RUSTZEN_DEPLOY_VERIFY_KEY=
